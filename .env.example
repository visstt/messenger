# Локальная разработка: скопируйте в .env и при необходимости измените.
# Продакшен (VPS): deploy/env.production — применяется автоматически через deploy/update.sh

APP_ORIGIN=http://localhost:3020
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# LIVEKIT_NODE_IP=

# MailerSend (https://www.mailersend.com/) — подтверждение почты и сброс пароля
MAILERSEND_API_KEY=
MAILERSEND_FROM_EMAIL=
MAILERSEND_FROM_NAME=Signal

