# Скопируйте в .env рядом с docker-compose.yml и подставьте свой домен.
# Без HTTPS браузер не отдаёт камеру/микрофон (кроме localhost).

APP_ORIGIN=https://chat.example.com
# Дополнительные Origin для CORS (через запятую), если заходите с нескольких URL.
# CORS_EXTRA_ORIGINS=https://chat.5-35-88-205.sslip.io

# WebSocket URL для клиента LiveKit: на проде обязательно wss://
# Часто отдельный поддомен с тем же nginx + сертификатом (см. deploy/host-nginx-messenger.example.conf).
LIVEKIT_PUBLIC_URL=wss://livekit.example.com

# Публичный IPv4 сервера для LiveKit (ICE). На VPS обязательно, иначе звонки зависают на «connecting».
# LIVEKIT_NODE_IP=203.0.113.10
