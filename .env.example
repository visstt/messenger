# Локальная разработка: скопируйте в .env и при необходимости измените.
# Продакшен (VPS): deploy/env.production — применяется автоматически через deploy/update.sh

APP_ORIGIN=http://localhost:3020
LIVEKIT_PUBLIC_URL=ws://localhost:7880
# LIVEKIT_NODE_IP=

# Админ-панель (/admin) — учётная запись создаётся при первом запуске, если таблица admin_users пуста
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-strong-password

# SMTP (подтверждение почты при регистрации).
# Если SMTP_* не заданы — регистрация сразу входит в аккаунт без кода.
# SMTP_HOST=mail.hosting.reg.ru
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=torguisam@torguisam.ru
SMTP_PASSWORD=change-me
SMTP_FROM=torguisam@torguisam.ru

